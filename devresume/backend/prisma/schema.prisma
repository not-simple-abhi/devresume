generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reviews Review[]

  @@map("users")
}

// Only stores the analysis result, NOT the resume text
model Review {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  resumeName   String   @map("resume_name")   // just the filename for display
  atsScore     Int      @map("ats_score")
  overallScore Int      @map("overall_score")
  reportJson   Json     @map("report_json")   // full AI report
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reviews")
}
